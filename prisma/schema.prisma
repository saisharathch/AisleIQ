// Prisma schema for Grocery Bill Calculator
// Supports SQLite for local dev and PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed; null for OAuth-only accounts
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sheetsSpreadsheetId String?   // persisted "Grocery Expense Tracker" spreadsheet ID

  accounts  Account[]
  sessions  Session[]
  receipts  Receipt[]
  editLogs  EditLog[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Receipts ──────────────────────────────────────────────────────────────

model Receipt {
  id            String        @id @default(cuid())
  userId        String
  storeName     String?
  fileUrl       String        // stored path or S3 key
  fileType      String        // "image/jpeg" | "image/png" | "image/heic" | "application/pdf"
  fileName      String
  fileSize      Int           // bytes
  status        String        @default("pending") // "pending" | "processing" | "done" | "failed"
  errorMessage  String?
  ocrRawText    String?       // raw OCR text for debugging
  subtotal      Float?
  totalTax      Float?
  discount      Float?
  grandTotal    Float?
  notes           String?
  sheetsUploadId  String?       // set after successful Google Sheets upload (prevents duplicates)
  uploadDate      DateTime      @default(now())
  processedAt   DateTime?
  updatedAt     DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    ReceiptItem[]
  editLogs EditLog[]

  @@index([userId])
  @@index([storeName])
  @@index([uploadDate])
}

model ReceiptItem {
  id            String   @id @default(cuid())
  receiptId     String
  store         String?  // may differ per item if multi-store receipt
  item          String
  quantity      Float?
  unitPrice     Float?
  lineTotal     Float?
  tax           Float?
  confidence    Float    @default(1.0) // 0.0–1.0; <0.7 = low confidence
  needsReview   Boolean  @default(false)
  sourceText    String?  // original OCR text region for this item
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipt  Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  editLogs EditLog[]

  @@index([receiptId])
}

// ─── Audit / Edit History ──────────────────────────────────────────────────

model EditLog {
  id            String   @id @default(cuid())
  userId        String
  receiptId     String
  receiptItemId String?
  field         String   // which field was changed
  oldValue      String?
  newValue      String?
  action        String   // "create" | "update" | "delete"
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  receipt     Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  receiptItem ReceiptItem? @relation(fields: [receiptItemId], references: [id])

  @@index([receiptId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Admin / Metrics ────────────────────────────────────────────────────────

model ParseLog {
  id          String   @id @default(cuid())
  receiptId   String
  success     Boolean
  duration    Int      // ms
  model       String?  // OCR model used
  errorCode   String?
  errorDetail String?
  createdAt   DateTime @default(now())

  @@index([success])
  @@index([createdAt])
}
