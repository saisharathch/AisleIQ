// Prisma schema for Grocery Bill Calculator
// Supports SQLite for local dev and PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed; null for OAuth-only accounts
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sheetsSpreadsheetId String?   // persisted "Grocery Expense Tracker" spreadsheet ID

  accounts  Account[]
  sessions  Session[]
  receipts  Receipt[]
  editLogs  EditLog[]
  categoryPreferences CategoryPreference[]
  budgets   Budget[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Receipts ──────────────────────────────────────────────────────────────

model Receipt {
  id            String        @id @default(cuid())
  userId        String
  storeName     String?
  purchaseDate  DateTime?
  fileUrl       String        // stored path or S3 key
  fileType      String        // "image/jpeg" | "image/png" | "image/heic" | "application/pdf"
  fileName      String
  fileSize      Int           // bytes
  fileHash      String?       // SHA-256 of raw file bytes — used for exact duplicate detection
  status        String        @default("queued") // "queued" | "processing" | "done" | "failed"
  overallConfidence Float?
  reviewStatus  String        @default("needs_review") // "needs_review" | "approved"
  reviewedAt    DateTime?
  errorMessage  String?
  ocrRawText    String?       // raw OCR text for debugging
  subtotal      Float?
  totalTax      Float?
  discount      Float?
  grandTotal    Float?
  syncStatus      String        @default("not_synced") // "not_synced" | "syncing" | "synced" | "failed" | "stale"
  syncErrorMessage String?
  syncAttempts     Int           @default(0)
  lastSyncHash     String?
  duplicateOfReceiptId String?
  duplicateScore      Float?
  duplicateReason     String?
  duplicateOverride   Boolean     @default(false)
  notes           String?
  paidBy          String?       // who paid (for roommate split)
  splitWith       String?       // JSON-serialized string[] of names to split with
  sheetsUploadId  String?       // spreadsheet ID of the Grocery Expense Tracker (set on first sync)
  sheetsSyncedAt  DateTime?     // timestamp of the most recent successful sync
  uploadDate      DateTime      @default(now())
  processedAt   DateTime?
  updatedAt     DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    ReceiptItem[]
  editLogs EditLog[]
  job      Job?

  @@index([userId])
  @@index([storeName])
  @@index([uploadDate])
  @@index([userId, fileHash])
}

// ─── Background Job Queue ──────────────────────────────────────────────────

model Job {
  id            String    @id @default(cuid())
  receiptId     String    @unique  // one active job per receipt; enforces idempotency
  status        String    @default("queued")  // "queued" | "processing" | "done" | "failed"
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  lastError     String?
  lockedAt      DateTime?           // set when a worker claims the job
  lockedBy      String?             // worker ID (for observability / multi-worker safety)
  nextAttemptAt DateTime  @default(now())  // controls backoff scheduling
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([lockedAt])
}

model ReceiptItem {
  id            String   @id @default(cuid())
  receiptId     String
  store         String?  // may differ per item if multi-store receipt
  item          String
  category      String?
  quantity      Float?
  unitPrice     Float?
  lineTotal     Float?
  tax           Float?
  confidence    Float    @default(1.0) // 0.0–1.0; <0.7 = low confidence
  needsReview   Boolean  @default(false)
  sourceText    String?  // original OCR text region for this item
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipt  Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  editLogs EditLog[]

  @@index([receiptId])
}

model CategoryPreference {
  id             String   @id @default(cuid())
  userId         String
  normalizedName String
  category       String
  usageCount     Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastUsedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, category])
}

// ─── Audit / Edit History ──────────────────────────────────────────────────

model EditLog {
  id            String   @id @default(cuid())
  userId        String
  receiptId     String
  receiptItemId String?
  field         String   // which field was changed
  oldValue      String?
  newValue      String?
  action        String   // "create" | "update" | "delete"
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  receipt     Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  receiptItem ReceiptItem? @relation(fields: [receiptItemId], references: [id])

  @@index([receiptId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Budgets ───────────────────────────────────────────────────────────────

model Budget {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int      // 1-12; 0 = yearly overall
  category  String?  // null = overall monthly budget
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month, category])
  @@index([userId, year, month])
}

// ─── Admin / Metrics ────────────────────────────────────────────────────────

model ParseLog {
  id          String   @id @default(cuid())
  receiptId   String
  success     Boolean
  duration    Int      // ms
  model       String?  // OCR model used
  errorCode   String?
  errorDetail String?
  createdAt   DateTime @default(now())

  @@index([success])
  @@index([createdAt])
}
