# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# For local dev: use SQLite via file:./dev.db
# For production: PostgreSQL connection string
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/grocery_bill_db"

# ──────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ──────────────────────────────────────────────
# Google OAuth + Sheets
# Required scopes: openid profile email https://www.googleapis.com/auth/spreadsheets
# In Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Also enable "Google Sheets API" in APIs & Services → Library
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ──────────────────────────────────────────────
# Anthropic (Claude Vision for OCR)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ──────────────────────────────────────────────
# File Storage
# Local dev: files stored in /public/uploads
# Production: use S3-compatible storage
# ──────────────────────────────────────────────
STORAGE_TYPE="local"  # "local" | "s3"

# AWS S3 (only needed when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT=""  # Optional: for S3-compatible services like Cloudflare R2

# ──────────────────────────────────────────────
# App Config
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MAX_FILE_SIZE_MB="10"
RATE_LIMIT_RPM="30"  # requests per minute per IP for upload endpoint
ADMIN_EMAIL="admin@example.com"
