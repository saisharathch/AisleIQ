# ──────────────────────────────────────────────────────────
# AisleIQ — .gitignore
# ──────────────────────────────────────────────────────────

# ── Environment & secrets (NEVER commit these) ────────────
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.example

# Generic secret/key file patterns
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.csr
*.keystore
*.jks
secrets.json
secrets.yaml
secrets.yml
secrets.toml
*secret*
*secrets*
*credentials*
*credential*
*.secret
service-account*.json
firebase-adminsdk*.json
google-credentials*.json
gcloud-credentials*.json

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Next.js build output ──────────────────────────────────
.next/
out/
build/
dist/

# ── Database files ────────────────────────────────────────
prisma/dev.db
prisma/dev.db-journal
prisma/dev.db-shm
prisma/dev.db-wal
prisma/*.db
prisma/*.db-journal
*.sqlite
*.sqlite3
*.db

# ── Uploaded files (local dev storage) ───────────────────
public/uploads/*
!public/uploads/.gitkeep

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── OS generated ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & editors ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/

# ── Testing & coverage ───────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ── Misc ─────────────────────────────────────────────────
.vercel
.turbo
*.tsbuildinfo
next-env.d.ts
